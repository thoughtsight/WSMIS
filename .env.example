# WSMIS Environment Configuration Template

# REQUIRED: Deployment environment flag.
# Valid options: "development", "production"
# The application will fail to start if this is missing or invalid.
WSMIS_ENV=production

# OPTIONAL: Google Service Account JSON (for Google Sheets access)
# Set this to the JSON content of your service account file.
# For local development, you can also place service_account.json in the project root (gitignored).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# OPTIONAL: Google Gemini API Key for AI Report generation
# GEMINI_API_KEY=AIza...

# OPTIONAL: Anthropic API Key for AI Report generation (alternative to Gemini)
# ANTHROPIC_API_KEY=sk-ant-api03...

# OPTIONAL: Google API Key (legacy, may be used for some services)
# GOOGLE_API_KEY=AIza...
